DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your_postgres_username
DB_NAME=regulus_ai
DATABASE_URL=postgresql+psycopg2://your_postgres_username@127.0.0.1:5432/regulus_ai

# Hugging Face Inference API token (https://huggingface.co/settings/tokens)
HF_API_TOKEN=your_huggingface_token
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Reasoning LLM provider: "huggingface" (default, uses HF_API_TOKEN) or "anthropic"
LLM_PROVIDER=huggingface
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
